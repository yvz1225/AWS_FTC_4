# Team-Up Sentinel Environment Variables

# [Backend]
GEMINI_API_KEY=your_google_gemini_api_key
NOTION_API_KEY=your_notion_integration_secret
NOTION_PARENT_DB_ID=your_notion_dashboard_db_id
GITHUB_TOKEN=your_github_personal_access_token
AWS_REGION=ap-northeast-2

# AWS Credentials (If not using default ~/.aws/credentials)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# [Frontend]
REACT_APP_API_URL=https://your-api-gateway-id.execute-api.ap-northeast-2.amazonaws.com/
